# API base URL — use your laptop IP for Wi-Fi demo (optional; auto-detected from browser hostname)
# VITE_API_BASE_URL=http://192.168.0.105:4000
# VITE_API_URL=http://192.168.0.105:4000

# Memorial portal URL for admin previews (optional)
# VITE_MEMORIAL_URL=http://192.168.0.105:5174

# Ports used for auto-detection when env vars are not set
VITE_API_PORT=4000
VITE_MEMORIAL_PORT=5174
