generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FuneralHome {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  address       String?
  logoUrl       String?
  plan          String         @default("demo")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  memorials     Memorial[]
  subscriptions Subscription[]
  payments      Payment[]
  usageLedger   UsageLedger[]
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String
  name          String
  role          String      @default("staff")
  funeralHomeId String
  funeralHome   FuneralHome @relation(fields: [funeralHomeId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Memorial {
  id                    String             @id @default(cuid())
  slug                  String             @unique
  deceasedName          String
  dateOfBirth           DateTime?
  dateOfDeath           DateTime?
  serviceDate           DateTime?
  serviceVenue          String?
  coverPhotoUrl         String?
  obituary              String?
  biography             Json?
  programme             Json
  currentProgrammeIndex Int                @default(0)
  announcements         Json
  settings              Json
  status                String             @default("draft")
  isDemo                Boolean            @default(false)
  funeralHomeId         String
  funeralHome           FuneralHome        @relation(fields: [funeralHomeId], references: [id])
  locations             MemorialLocation[]
  photos                Photo[]
  tributes              Tribute[]
  usageLedger           UsageLedger?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
}

model Plan {
  id                  String         @id @default(cuid())
  code                String         @unique
  name                String
  amount              Int
  currency            String         @default("ZAR")
  interval            String         @default("monthly")
  memorialLimit       Int
  extraMemorialAmount Int
  fairUseUnlimited    Boolean        @default(false)
  active              Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  subscriptions       Subscription[]
  payments            Payment[]
}

model Subscription {
  id                       String        @id @default(cuid())
  funeralHomeId            String
  funeralHome              FuneralHome   @relation(fields: [funeralHomeId], references: [id], onDelete: Cascade)
  planId                   String
  plan                     Plan          @relation(fields: [planId], references: [id])
  status                   String        @default("pending")
  paystackCustomerCode     String?
  paystackSubscriptionCode String?       @unique
  paystackEmailToken       String?
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean       @default(false)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  payments                 Payment[]
  usageLedger              UsageLedger[]

  @@unique([funeralHomeId])
  @@index([status, currentPeriodEnd])
}

model Payment {
  id                    String        @id @default(cuid())
  funeralHomeId         String
  funeralHome           FuneralHome   @relation(fields: [funeralHomeId], references: [id], onDelete: Cascade)
  subscriptionId        String?
  subscription          Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  planId                String?
  plan                  Plan?         @relation(fields: [planId], references: [id], onDelete: SetNull)
  kind                  String
  status                String        @default("pending")
  amount                Int
  currency              String        @default("ZAR")
  paystackReference     String        @unique
  paystackTransactionId String?
  paidAt                DateTime?
  failureMessage        String?
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([funeralHomeId, status, createdAt])
}

model UsageLedger {
  id             String        @id @default(cuid())
  funeralHomeId  String
  funeralHome    FuneralHome   @relation(fields: [funeralHomeId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  memorialId     String        @unique
  memorial       Memorial      @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  type           String        @default("memorial_published")
  quantity       Int           @default(1)
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime      @default(now())

  @@index([funeralHomeId, periodStart, periodEnd])
}

model MemorialLocation {
  id          String   @id @default(cuid())
  memorialId  String
  memorial    Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  type        String
  name        String
  addressText String?
  latitude    Float
  longitude   Float
  notes       String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([memorialId, orderIndex])
}

model Photo {
  id         String   @id @default(cuid())
  memorialId String
  memorial   Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  category   String   @default("other")
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model Tribute {
  id         String   @id @default(cuid())
  memorialId String
  memorial   Memorial @relation(fields: [memorialId], references: [id], onDelete: Cascade)
  authorName String
  message    String
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}
