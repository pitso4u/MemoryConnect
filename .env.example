# API Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-in-production-min-16-chars
JWT_EXPIRES_IN=7d

# CORS — use * for local-network demo (phones on same Wi-Fi)
CORS_ORIGIN=*

# Database (SQLite — no external services required)
DATABASE_URL="file:./dev.db"

# Optional explicit URLs (auto-detected if omitted)
# ADMIN_URL=http://192.168.0.105:5173
# MEMORIAL_URL=http://192.168.0.105:5174
# API_URL=http://192.168.0.105:4000

# Paystack billing (use sk_test_... locally and sk_live_... in production)
PAYSTACK_SECRET_KEY=
# Create monthly ZAR plans in Paystack, then paste their non-secret PLN_... codes here
PAYSTACK_STARTER_PLAN_CODE=
PAYSTACK_PROFESSIONAL_PLAN_CODE=
PAYSTACK_UNLIMITED_PLAN_CODE=
