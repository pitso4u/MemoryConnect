# API Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-in-production-min-16-chars
JWT_EXPIRES_IN=7d

# CORS — use * for local-network demo (phones on same Wi-Fi)
CORS_ORIGIN=*

# Database (SQLite — no external services required)
DATABASE_URL="file:./dev.db"

# Optional explicit URLs (auto-detected if omitted)
# ADMIN_URL=http://192.168.0.105:5173
# MEMORIAL_URL=http://192.168.0.105:5174
# API_URL=http://192.168.0.105:4000
